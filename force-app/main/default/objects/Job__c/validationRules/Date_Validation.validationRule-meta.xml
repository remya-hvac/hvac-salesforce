<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Date_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>DATETIMEVALUE( Target_Filled_Date__c ) &lt;     NOW()</errorConditionFormula>
    <errorMessage>Target Filled Date cannot be past date</errorMessage>
</ValidationRule>
