<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Age_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>Age__c &lt; 20 ||  ISBLANK(Age__c)</errorConditionFormula>
    <errorMessage>Age should be greater than 20</errorMessage>
</ValidationRule>
